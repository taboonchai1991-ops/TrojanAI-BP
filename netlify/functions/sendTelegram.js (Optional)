exports.handler = async (event) => {
    const headers = { 'Access-Control-Allow-Origin': '*', 'Access-Control-Allow-Headers': 'Content-Type' };
    if (event.httpMethod === 'OPTIONS') return { statusCode: 204, headers, body: '' };
    if (event.httpMethod !== 'POST') return { statusCode: 405, headers, body: JSON.stringify({ error: 'Method not allowed' }) };
    
    try {
        const { relayName, action, botToken, chatId } = JSON.parse(event.body);
        const message = `🔌 *TrojanAI (BP)*\n📡 ${relayName}\n⚡ ${action === 'ON' ? 'เปิด' : 'ปิด'}\n⏰ ${new Date().toLocaleString('th-TH')}`;
        const response = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chat_id: chatId, text: message, parse_mode: 'Markdown' })
        });
        const result = await response.json();
        return { statusCode: 200, headers, body: JSON.stringify({ success: result.ok }) };
    } catch (error) {
        return { statusCode: 500, headers, body: JSON.stringify({ error: error.message }) };
    }
};
